#:kivy 1.9
#:import hsv_to_rgb colorsys.hsv_to_rgb
#:import rgb_to_hsv colorsys.rgb_to_hsv

<LampetScreen>:
    FloatLayout:
        canvas.before:
            Color:
                rgba: 0.95, 0.85, 0.60, 1
            Rectangle:
                pos: self.pos
                size: self.size

        LAMPetSprite:
            size_hint: (None, None)
            size: (root.width/4, root.width/4)
            x: app.lampet_x
            y: app.lampet_y

        BoxLayout:
            size_hint: (0.5, 0.3)
            pos_hint: {'x': 0, 'top': 1}
            orientation: 'vertical'
            padding: dp(10)
            AttributeBar:
                icon_source: 'images/cutlery.png'
                value: app.hunger
            AttributeBar:
                icon_source: 'images/drop.png'
                value: app.cleanliness
            AttributeBar:
                icon_source: 'images/happy-face.png'
                value: app.happiness

        BoxLayout:
            size_hint: (1, 0.2)
            orientation: 'horizontal'
            ToggleButton:
                size_hint_x: 0.25
                text: 'feed'
                state: 'down' if app.feeding_mode else 'normal'
                on_state:
                    app.feeding_mode = (self.state == "down")
            Button:
                size_hint_x: 0.25
                text: 'swap\npage'
                on_release: root.manager.current = 'lampi'
